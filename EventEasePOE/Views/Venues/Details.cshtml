@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<h1>Venue Details</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4>@Model.VenueName</h4>
            </div>
            <div class="card-body">
                <img src="@Model.ImageURL" class="img-fluid rounded mb-3" style="max-height: 300px; width: 100%; object-fit: cover;" onerror="this.src='https://picsum.photos/id/20/400/300'" />

                <dl class="row">
                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.VenueName)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.VenueName)
                    </dd>
                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.VenueLocation)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.VenueLocation)
                    </dd>
                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.Capacity)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.Capacity) people
                    </dd>
                    <dt class="col-sm-4">
                        Image URL
                    </dt>
                    <dd class="col-sm-8">
                        <a href="@Model.ImageURL" target="_blank">@Model.ImageURL</a>
                    </dd>
                </dl>
            </div>
            <div class="card-footer">
                <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">Edit</a>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>