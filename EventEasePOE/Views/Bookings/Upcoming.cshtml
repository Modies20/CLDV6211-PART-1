@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Upcoming Bookings";
}

<h1>Upcoming Bookings</h1>
<p class="text-muted">Showing @ViewBag.Count upcoming bookings</p>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
    <a asp-action="Index" class="btn btn-secondary">All Bookings</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-success">
            <tr>
                <th>Booking ID</th>
                <th>Event</th>
                <th>Venue</th>
                <th>Start Date/Time</th>
                <th>End Date/Time</th>
                <th>Customer</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.BookingId</td>
                    <td>@item.Event?.EventName</td>
                    <td>@item.Venue?.VenueName</td>
                    <td>@item.StartDateTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                    <td>@item.EndDateTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                    <td>@item.CustomerName</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success text-center">
        <h4>No upcoming bookings</h4>
        <p>All clear! No upcoming events scheduled.</p>
    </div>
}
