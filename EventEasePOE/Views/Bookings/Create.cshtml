@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Create Booking";
}

<h1>Create New Booking</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="EventId" class="control-label">Select Event</label>
                <select asp-for="EventId" class="form-control" asp-items="ViewBag.EventId">
                    <option value="">-- Select Event --</option>
                </select>
                <span asp-validation-for="EventId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="VenueId" class="control-label">Select Venue</label>
                <select asp-for="VenueId" class="form-control" asp-items="ViewBag.VenueId">
                    <option value="">-- Select Venue --</option>
                </select>
                <span asp-validation-for="VenueId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StartDateTime" class="control-label">Start Date & Time</label>
                <input asp-for="StartDateTime" class="form-control" type="datetime-local" value="@ViewBag.DefaultStart" />
                <span asp-validation-for="StartDateTime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EndDateTime" class="control-label">End Date & Time</label>
                <input asp-for="EndDateTime" class="form-control" type="datetime-local" value="@ViewBag.DefaultEnd" />
                <span asp-validation-for="EndDateTime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CustomerName" class="control-label">Customer Name</label>
                <input asp-for="CustomerName" class="form-control" />
                <span asp-validation-for="CustomerName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CustomerEmail" class="control-label">Customer Email</label>
                <input asp-for="CustomerEmail" class="form-control" type="email" />
                <span asp-validation-for="CustomerEmail" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BookingStatus" class="control-label">Booking Status</label>
                <select asp-for="BookingStatus" class="form-control">
                    <option value="Confirmed">Confirmed</option>
                    <option value="Pending">Pending</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
                <span asp-validation-for="BookingStatus" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create Booking" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="card bg-light">
            <div class="card-header bg-info text-white">
                <strong>Booking Information</strong>
            </div>
            <div class="card-body">
                <h5>Important Notes:</h5>
                <ul>
                    <li>Bookings cannot overlap for the same venue</li>
                    <li>End time must be after start time</li>
                    <li>Cannot book past dates</li>
                    <li>Customer email is optional but recommended</li>
                </ul>
                <hr />
                <h5>Venue Capacity Information:</h5>
                <div id="venueInfo">
                    <p class="text-muted">Select a venue to see capacity details</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $('#VenueId').change(function() {
            var venueId = $(this).val();
            if (venueId) {
                $.get('/Venues/GetVenueInfo/' + venueId, function(data) {
                    $('#venueInfo').html('<p><strong>' + data.venueName + '</strong><br>Location: ' + data.location + '<br>Capacity: ' + data.capacity + ' people</p>');
                });
            }
        });
    </script>
}

