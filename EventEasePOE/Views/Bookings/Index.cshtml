@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>
<p class="text-muted">Manage all venue bookings</p>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
    <a asp-action="Upcoming" class="btn btn-info">View Upcoming</a>
    <a asp-action="Calendar" class="btn btn-secondary">Calendar View</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Booking ID</th>
                <th>Event</th>
                <th>Venue</th>
                <th>Start Date/Time</th>
                <th>End Date/Time</th>
                <th>Customer</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.StartDateTime < DateTime.Now ? "table-secondary" : "")">
                    <td>@item.BookingId</td>
                    <td>@item.Event?.EventName</td>
                    <td>@item.Venue?.VenueName</td>
                    <td>@item.StartDateTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                    <td>@item.EndDateTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                    <td>@item.CustomerName</td>
                    <td>
                        @if (item.BookingStatus == "Confirmed")
                        {
                            <span class="badge bg-success">Confirmed</span>
                        }
                        else if (item.BookingStatus == "Cancelled")
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                        else if (item.BookingStatus == "Completed")
                        {
                            <span class="badge bg-secondary">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">@item.BookingStatus</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger">Cancel</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <h4>No bookings found</h4>
        <p>Click "Create New Booking" to add your first booking.</p>
    </div>
}